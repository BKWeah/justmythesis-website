<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="successGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2744"/>
      <stop offset="50%" style="stop-color:#2a3a5c"/>
      <stop offset="100%" style="stop-color:#1a2744"/>
    </linearGradient>
    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:rgba(212,168,71,0.4)"/>
      <stop offset="100%" style="stop-color:transparent"/>
    </radialGradient>
  </defs>
  <rect width="800" height="600" fill="url(#successGrad)"/>
  <circle cx="400" cy="300" r="200" fill="url(#glow)"/>
  <g transform="translate(400, 280)">
    <path d="M0,-80 L25,10 L80,10 L35,45 L55,100 L0,65 L-55,100 L-35,45 L-80,10 L-25,10 Z" fill="rgba(212,168,71,0.9)"/>
  </g>
  <text x="400" y="480" text-anchor="middle" fill="#d4a847" font-family="Georgia, serif" font-size="24" font-weight="bold">Graduate Success</text>
  <text x="400" y="510" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="Arial, sans-serif" font-size="16">Your Achievement Awaits</text>
</svg>
