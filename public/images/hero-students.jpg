<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="heroGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2744"/>
      <stop offset="50%" style="stop-color:#2a3a5c"/>
      <stop offset="100%" style="stop-color:#1a2744"/>
    </linearGradient>
    <pattern id="dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
      <circle cx="2" cy="2" r="1" fill="rgba(212,168,71,0.3)"/>
    </pattern>
  </defs>
  <rect width="800" height="600" fill="url(#heroGrad)"/>
  <rect width="800" height="600" fill="url(#dots)"/>
  <g transform="translate(400, 300)">
    <circle r="80" fill="rgba(212,168,71,0.2)"/>
    <circle r="60" fill="rgba(212,168,71,0.3)"/>
    <path d="M-25,-15 L25,-15 L0,25 Z" fill="rgba(212,168,71,0.8)"/>
  </g>
  <text x="400" y="480" text-anchor="middle" fill="#d4a847" font-family="Georgia, serif" font-size="24" font-weight="bold">Academic Excellence</text>
  <text x="400" y="510" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="Arial, sans-serif" font-size="16">Supporting Your Research Journey</text>
</svg>
