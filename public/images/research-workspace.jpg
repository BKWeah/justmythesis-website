<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="researchGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2744"/>
      <stop offset="50%" style="stop-color:#2a3a5c"/>
      <stop offset="100%" style="stop-color:#1a2744"/>
    </linearGradient>
    <radialGradient id="spotlight" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:rgba(212,168,71,0.3)"/>
      <stop offset="100%" style="stop-color:transparent"/>
    </radialGradient>
  </defs>
  <rect width="800" height="600" fill="url(#researchGrad)"/>
  <ellipse cx="400" cy="300" rx="300" ry="200" fill="url(#spotlight)"/>
  <g transform="translate(400, 300)">
    <rect x="-120" y="-80" width="240" height="160" rx="4" fill="rgba(255,255,255,0.1)" stroke="rgba(212,168,71,0.5)" stroke-width="2"/>
    <rect x="-100" y="-60" width="180" height="100" fill="rgba(212,168,71,0.2)"/>
    <circle cx="-50" cy="-10" r="25" fill="rgba(212,168,71,0.6)"/>
    <rect x="0" y="-40" width="60" height="8" fill="rgba(255,255,255,0.7)"/>
    <rect x="0" y="-20" width="50" height="6" fill="rgba(255,255,255,0.5)"/>
    <rect x="0" y="0" width="55" height="6" fill="rgba(255,255,255,0.5)"/>
  </g>
  <text x="400" y="480" text-anchor="middle" fill="#d4a847" font-family="Georgia, serif" font-size="24" font-weight="bold">Research Workspace</text>
  <text x="400" y="510" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="Arial, sans-serif" font-size="16">Organized for Excellence</text>
</svg>
